# Copy to .env and fill in what you use. Everything is optional —
# the app runs with zero LLM keys (chat will say no provider is configured).

# Seed demo data on first boot (idempotent; skipped if goals exist)
SEED_DEMO_DATA=true

# --- LLM providers (set any subset; availability is auto-detected) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# AWS Bedrock (Claude models on Bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Ollama (local models). From inside Docker, host Ollama is reachable at
# http://host.docker.internal:11434 (the compose default).
OLLAMA_BASE_URL=http://host.docker.internal:11434
