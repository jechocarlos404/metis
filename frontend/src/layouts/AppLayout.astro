---
import HealthBadges from "../components/shell/HealthBadges.jsx";
import { ICONS } from "../ds/Icons.jsx";
import "../styles/global.css";

const NAV = [
  { href: "/chat", label: "Chat", icon: "message-square" },
  { href: "/goals", label: "Goals", icon: "target" },
  { href: "/capabilities", label: "Capabilities", icon: "layers" },
  { href: "/features", label: "Features", icon: "network" },
  { href: "/products", label: "Products", icon: "package" },
  { href: "/admin", label: "LLM Config", icon: "settings" },
];

const { title = "Metis" } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href) => path === href || path.startsWith(href + "/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · metis</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div style="display:flex; height:100vh; background:var(--surface-page); overflow:hidden;">
      <aside
        style="width:216px; flex:none; border-right:1px solid var(--border-hairline); background:var(--surface-card); display:flex; flex-direction:column;"
      >
        <div style="padding:18px 20px 14px; display:flex; align-items:baseline; gap:8px;">
          <span
            style="font-family:var(--font-display); font-weight:var(--weight-semibold); font-size:20px; letter-spacing:var(--tracking-tight); color:var(--text-heading);"
            >metis</span
          >
          <span style="font-family:var(--font-mono); font-size:10px; color:var(--text-disabled);"
            >v0.1</span
          >
        </div>
        <nav style="display:flex; flex-direction:column; gap:2px; padding:0 10px;">
          {
            NAV.map((item) => {
              const active = isActive(item.href);
              return (
                <a
                  href={item.href}
                  style={`display:flex; align-items:center; gap:10px; padding:8px 10px; text-decoration:none;
                    background:${active ? "var(--surface-inset)" : "transparent"};
                    color:${active ? "var(--text-heading)" : "var(--text-secondary)"};
                    font-weight:${active ? "var(--weight-semibold)" : "var(--weight-regular)"};
                    border-radius:var(--radius-sm); font-family:var(--font-body); font-size:var(--text-sm);`}
                >
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style={`flex:none; color:${active ? "var(--text-accent)" : "var(--text-disabled)"};`}
                  >
                    {(ICONS[item.icon] || []).map((n) =>
                      n[0] === "path" ? (
                        <path d={n[1]} />
                      ) : n[0] === "circle" ? (
                        <circle cx={n[1]} cy={n[2]} r={n[3]} />
                      ) : (
                        <rect x={n[1]} y={n[2]} width={n[3]} height={n[4]} rx={n[5]} />
                      ),
                    )}
                  </svg>
                  {item.label}
                </a>
              );
            })
          }
        </nav>
        <div
          style="margin-top:auto; padding:16px; border-top:1px solid var(--border-hairline); display:flex; flex-direction:column; gap:6px;"
        >
          <div
            style="font-family:var(--font-mono); font-size:10px; letter-spacing:var(--tracking-caps); text-transform:uppercase; color:var(--text-disabled);"
          >
            Pipeline health
          </div>
          <HealthBadges client:idle />
        </div>
      </aside>
      <main style="flex:1; min-width:0; display:flex; flex-direction:column; overflow:hidden;">
        <slot />
      </main>
    </div>
  </body>
</html>
